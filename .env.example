# ─────────────────────────────────────────────────────────────────────────────
#  Environment Variables — copy to .env and fill in real values
#  NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# App
FLASK_ENV=development               # development | testing | staging | production
APP_NAME=FlaskTemplate

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/flask_template_dev

# Redis (required for staging/production cache and rate limiting)
REDIS_URL=redis://localhost:6379/0

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Server
HOST=0.0.0.0
PORT=5000
